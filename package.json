  "description": "Trusted Shopify and ecommerce diagnostics for operators who need cleaner revenue decisions",
  "main": "index.js",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "alpinejs": "^3.15.9",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.4.19",
    "test": "^3.3.0"
  },
  "scripts": {
    "start": "concurrently npm:watch:*",
    "watch:tw": "tailwindcss -i ./assets/css/main.css -o ./assets/css/style.css --watch",
    "watch:hugo": "hugo server --disableFastRender",
    "build": "hugo --gc --minify",
    "test": "node --test test/scorecard.test.cjs && hugo"
  },
